  issn = {1615-3375, 1615-3383},
  doi = {10.1007/s10208-023-09630-x},
  urldate = {2026-02-16},
  abstract = {Transportation of measure provides a versatile approach for modeling complex probability distributions, with applications in density estimation, Bayesian inference, generative modeling, and beyond. Monotone triangular transport maps\$\textbackslash unicode\textbraceleft x2014\textbraceright\$approximations of the Knothe\$\textbackslash unicode\textbraceleft x2013\textbraceright\$Rosenblatt (KR) rearrangement\$\textbackslash unicode\textbraceleft x2014\textbraceright\$are a canonical choice for these tasks. Yet the representation and parameterization of such maps have a significant impact on their generality and expressiveness, and on properties of the optimization problem that arises in learning a map from data (e.g., via maximum likelihood estimation). We present a general framework for representing monotone triangular maps via invertible transformations of smooth functions. We establish conditions on the transformation such that the associated infinite-dimensional minimization problem has no spurious local minima, i.e., all local minima are global minima; and we show for target distributions satisfying certain tail conditions that the unique global minimizer corresponds to the KR map. Given a sample from the target, we then propose an adaptive algorithm that estimates a sparse semi-parametric approximation of the underlying KR map. We demonstrate how this framework can be applied to joint and conditional density estimation, likelihood-free inference, and structure learning of directed graphical models, with stable generalization performance across a range of sample sizes.},
  archiveprefix = {arXiv},
  keywords = {Computer Science - Machine Learning,Mathematics - Functional Analysis,Statistics - Computation,Statistics - Machine Learning,Statistics - Methodology},
  file = {/Users/ashleyturner/Zotero/storage/KAIUL5YH/Baptista et al. - 2024 - On the representation and learning of monotone triangular transport maps.pdf;/Users/ashleyturner/Zotero/storage/I9LLMV9Q/2009.html}
}

@misc{Ben-Hamu_2022,
  title = {Matching {{Normalizing Flows}} and {{Probability Paths}} on {{Manifolds}}},
  author = {{Ben-Hamu}, Heli and Cohen, Samuel and Bose, Joey and Amos, Brandon and Grover, Aditya and Nickel, Maximilian and Chen, Ricky T. Q. and Lipman, Yaron},
  year = 2022,
  month = jul,
  number = {arXiv:2207.04711},
